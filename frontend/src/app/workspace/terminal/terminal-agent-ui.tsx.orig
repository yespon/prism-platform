import React, { useState, useEffect } from 'react';
import { useTerminalAgent } from '@/core/terminal-agent/useTerminalAgent';
import { useTerminalContext } from '@/app/workspace/terminal/context';
import { 
  Monitor, 
  X, 
  Plus, 
  RotateCcw, 
  MoreHorizontal, 
  Mic, 
  Image as ImageIcon,
  ArrowUp,
  ChevronDown
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from '@/components/ui/dropdown-menu';
import { useAvailableModels } from '@/core/models/hooks';

export function TerminalAgentUI({ activeAsset }: { activeAsset: any }) {
  const terminalContext = useTerminalContext();
  const { models } = useAvailableModels();
  const [selectedModel, setSelectedModel] = useState<string>('gpt-4o');

  useEffect(() => {
    if (models.length > 0 && !models.find(m => m.name === selectedModel)) {
      setSelectedModel(models[0].name);
    }
  }, [models]);

  const {
    messages,
    input,
    handleInputChange,
    handleSubmit,
    isLoading,
    isDetectingInteraction,
    todos,
    detectInteraction,
    addToolResult,
    focusChain
  } = useTerminalAgent({
    taskId: 'terminal-session',
    modelName: selectedModel,
  });

  return (
    <div className="w-[380px] h-full flex flex-col bg-[#fafafa] shrink-0 border-l border-zinc-200 relative z-10">
      {/* Chat Tabs / Header */}
      <div className="flex items-center justify-between h-10 border-b border-zinc-200 px-3 bg-zinc-50/80">
        <div className="flex items-center gap-2 px-3 py-1.5 text-blue-600 font-medium bg-white border border-zinc-200 border-b-white rounded-t-lg -mb-[1px]">
          Chaterm Agent
          <button className="hover:bg-zinc-100 rounded-sm p-0.5 text-zinc-400 hover:text-zinc-600">
            <X className="w-3.5 h-3.5" />
          </button>
        </div>
        <div className="flex items-center gap-1 text-zinc-500">
          <Button variant="ghost" size="icon" className="h-7 w-7 rounded-md hover:bg-zinc-200/50">
            <Plus className="w-4 h-4" />
          </Button>
          <Button variant="ghost" size="icon" className="h-7 w-7 rounded-md hover:bg-zinc-200/50">
            <RotateCcw className="w-4 h-4" />
          </Button>
          <Button variant="ghost" size="icon" className="h-7 w-7 rounded-md hover:bg-zinc-200/50">
            <MoreHorizontal className="w-4 h-4" />
          </Button>
        </div>
      </div>
      
      {/* Chat Content */}
      <div className="flex-1 flex flex-col overflow-y-auto p-4 space-y-4">
        {messages.length === 0 ? (
          <div className="flex-1 flex flex-col items-center justify-center text-zinc-400">
            <div className="w-10 h-10 rounded-full border-2 border-zinc-300 flex items-center justify-center mb-3">
              <span className="font-semibold text-lg text-zinc-400">AI</span>
            </div>
            <p className="text-xs">Chaterm Agent Ready.</p>
          </div>
        ) : (
          messages.map((m) => (
            <div key={m.id} className={`flex flex-col \${m.role === 'user' ? 'items-end' : 'items-start'}`}>
              {m.role === 'user' && (
                <div className="bg-blue-600 text-white px-3 py-2 rounded-xl max-w-[90%] text-[13px]">
                  {m.content}
                </div>
              )}
              {m.role === 'assistant' && (
                <div className="bg-white border border-zinc-200 px-3 py-2 rounded-xl max-w-[90%] text-[13px] text-zinc-800">
                  {/* @ts-expect-error */}
                  {m.content || (m.toolInvocations ? <span className="text-zinc-500 italic">Thinking and using tools...</span> : null)}
                  {/* @ts-expect-error */}
                  {m.toolInvocations?.map((tool: any) => {
                    if (tool.toolName === 'execute_command') {
                      return (
                        <div key={tool.toolCallId} className="mt-2 flex flex-col rounded-md border border-zinc-200 overflow-hidden text-left shadow-sm">
                          <div className="bg-zinc-100 px-3 py-1.5 flex items-center justify-between border-b border-zinc-200">
                            <span className="text-[12px] font-semibold text-zinc-700 flex items-center gap-1.5">
                              <TerminalSquare className="w-3.5 h-3.5 text-blue-600" />
                              准备执行命令
                            </span>
                            {tool.state === 'result' ? (
                              <span className="text-[11px] font-medium text-emerald-600 bg-emerald-50 border border-emerald-200/50 px-1.5 py-0.5 rounded">已执行</span>
                            ) : (
                              <span className="text-[11px] font-medium text-amber-600 bg-amber-50 border border-amber-200/50 px-1.5 py-0.5 rounded">等待确认</span>
                            )}
                          </div>
                          <div className="p-3 bg-[#0d1117] text-zinc-100 text-[12px] font-mono overflow-x-auto whitespace-pre-wrap">
                            {tool.args.command}
                          </div>
                          {tool.args.reason && (
                            <div className="px-3 py-2 bg-white text-[11px] text-zinc-500 border-t border-zinc-100">
                              <span className="font-medium text-zinc-600">意图：</span>{tool.args.reason}
                            </div>
                          )}
                          {tool.state === 'call' && (
                            <div className="flex bg-zinc-50 border-t border-zinc-200 p-2 gap-2 justify-end">
                              <Button 
                                variant="outline" 
                                size="sm" 
                                className="h-7 text-xs bg-white text-zinc-600 hover:text-red-600"
                                onClick={() => addToolResult({ toolCallId: tool.toolCallId, result: '用户拒绝了该命令的执行。' })}
                              >
                                拒绝执行
                              </Button>
                              <Button 
                                size="sm" 
                                className="h-7 text-xs bg-blue-600 hover:bg-blue-700 text-white"
                                onClick={async () => {
                                  try {
                                    if (!terminalContext?.executeCommand) throw new Error('Terminal not ready');
                                    const output = await terminalContext.executeCommand(tool.args.command);
                                    const detection = await detectInteraction(tool.args.command, output);
                                    if (detection?.needsInteraction) {
                                      addToolResult({ toolCallId: tool.toolCallId, result: `[Interaction Required: ${detection.promptHint || 'User input needed'}]\n${output}` });
                                    } else {
                                      addToolResult({ toolCallId: tool.toolCallId, result: output });
                                    }
                                  } catch (e: any) {
                                    addToolResult({ toolCallId: tool.toolCallId, result: `Command execution failed: ${e.message}` });
                                  }
                                }}
                              >
                                允许运行
                              </Button>
                            </div>
                          )}
                        </div>
                      );
                    }

                    return (
                      <div key={tool.toolCallId} className="mt-2 p-2 bg-zinc-50 rounded border border-zinc-100 text-[11px] font-mono">
                        <div className="font-semibold text-zinc-600 mb-1">🛠 {tool.toolName}</div>
                        <div>{JSON.stringify(tool.args)}</div>
                      </div>
                    );
                  })}
                </div>
              )}
              {m.role === 'tool' && (
                <div className="bg-zinc-800 text-zinc-100 px-3 py-2 rounded-xl max-w-[90%] text-[11px] font-mono mt-1 overflow-x-auto whitespace-pre-wrap">
                  {m.content}
                </div>
              )}
            </div>
          ))
        )}
        {isLoading && (
          <div className="flex items-center gap-2 text-zinc-400 text-xs">
            <div className="w-2 h-2 rounded-full bg-zinc-400 animate-pulse" />
            <span>Agent is typing...</span>
          </div>
        )}
        {isDetectingInteraction && (
          <div className="flex items-center gap-2 text-blue-500 text-xs">
            <div className="w-2 h-2 rounded-full bg-blue-500 animate-pulse" />
            <span>Detecting interaction...</span>
          </div>
        )}
      </div>

      {/* Chat Input Box */}
      <div className="p-4">
        <form onSubmit={handleSubmit} className="bg-white border border-zinc-200 rounded-xl shadow-sm flex flex-col overflow-hidden focus-within:border-blue-400 focus-within:ring-1 focus-within:ring-blue-400/20 transition-all">
          {/* Context Chip */}
          <div className="px-3 pt-3">
            <div className="inline-flex items-center gap-1.5 bg-blue-50 text-blue-600 text-[11px] px-2 py-1 rounded-md font-medium border border-blue-100">
              <span className="text-zinc-400 text-[10px]">@</span>
              <Monitor className="w-3 h-3" />
              {activeAsset ? activeAsset.ip : 'localhost'}
              <button className="hover:bg-blue-100 rounded-sm p-0.5 ml-0.5">
                <X className="w-2.5 h-2.5" />
              </button>
            </div>
          </div>
          
          {/* Input */}
          <textarea 
            value={input || ''}
            onChange={handleInputChange}
            onKeyDown={(e) => {
              if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                handleSubmit(e as any);
              }
            }}
            placeholder="到任意主机执行命令查询，排查错误和任务处理等任何事情"
            className="w-full bg-transparent border-0 resize-none px-4 py-2.5 text-[13px] text-zinc-800 placeholder:text-zinc-400 focus:outline-none focus:ring-0 min-h-[60px]"
          />
          
          {/* Footer */}
          <div className="flex items-center justify-between px-3 py-2 bg-white border-t border-zinc-100/50">
            <div className="flex items-center gap-3">
              <button type="button" className="flex items-center gap-1 text-[11px] font-medium text-zinc-600 hover:text-zinc-900">
                Agent
                <ChevronDown className="w-3 h-3 text-zinc-400" />
              </button>
              <DropdownMenu>
                <DropdownMenuTrigger asChild>
                  <button type="button" className="flex items-center gap-1 text-[11px] font-medium text-zinc-600 hover:text-zinc-900">
                    {selectedModel}
                    <ChevronDown className="w-3 h-3 text-zinc-400" />
                  </button>
                </DropdownMenuTrigger>
                <DropdownMenuContent align="end" className="text-[12px]">
                  {models.map(m => (
                    <DropdownMenuItem key={m.name} onClick={() => setSelectedModel(m.name)}>
                      {m.display_name || m.name}
                    </DropdownMenuItem>
                  ))}
                </DropdownMenuContent>
              </DropdownMenu>
            </div>
            
            <div className="flex items-center gap-2">
              <button type="button" className="text-zinc-400 hover:text-zinc-600 transition-colors p-1">
                <ImageIcon className="w-4 h-4" />
              </button>
              <button type="button" className="text-zinc-400 hover:text-zinc-600 transition-colors p-1">
                <Mic className="w-4 h-4" />
              </button>
              <Button type="submit" size="icon" disabled={!input?.trim() || isLoading} className="h-7 w-7 rounded-full bg-blue-500 hover:bg-blue-600 text-white shadow-sm ml-1">
                <ArrowUp className="w-3.5 h-3.5" />
              </Button>
            </div>
          </div>
        </form>
      </div>
    </div>
  );
}
